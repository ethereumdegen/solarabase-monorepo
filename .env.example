# === REQUIRED ===

# Neon Postgres
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/solarabase?sslmode=require

# LLM (for PageIndex indexing + RAG agent)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Server
HOST=0.0.0.0
PORT=3000
PUBLIC_URL=http://localhost:3000

# === OPTIONAL — features degrade gracefully if missing ===

# DigitalOcean Spaces (S3-compatible) — without this, document upload/indexing is disabled
#S3_REGION=nyc3
#S3_ACCESS_KEY=xxx
#S3_SECRET_KEY=xxx
#S3_BUCKET=solarabase-docs
#S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Google OAuth — without this, only dev login is available (POST /auth/dev-login)
#GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=xxx
#GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Stripe — without this, billing is disabled (all workspaces get free plan)
#STRIPE_SECRET_KEY=sk_test_xxx
#STRIPE_WEBHOOK_SECRET=whsec_xxx
#STRIPE_PRO_PRICE_ID=price_xxx
#STRIPE_TEAM_PRICE_ID=price_xxx
